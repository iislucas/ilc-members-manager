rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      let email = request.auth.token.email;
      let aclPath = /databases/(default)/documents/acl/$(email);
      return email != null && firestore.get(aclPath).data.isAdmin == true;
    }

    match /backups/{backupFile} {
      // Only admins can read/write the backups
      allow read, write: if isAdmin();
    }
    
    match /events/{eventId}/heroImage {
      allow read: if true;
      allow write: if isAdmin() || (
        request.auth != null &&
        (
          request.auth.token.email == firestore.get(/databases/(default)/documents/events/$(eventId)).data.ownerEmail ||
          request.auth.token.email in firestore.get(/databases/(default)/documents/events/$(eventId)).data.get('managerEmails', [])
        )
      );
    }

    match /{allPaths=**} {
      // Deny by default
      allow read, write: if false;
    }
  }
}
