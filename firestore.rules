rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      let email = request.auth.token.email;
      let aclPath = /databases/$(database)/documents/acl/$(email);
      return email != null && exists(aclPath) && get(aclPath).data.isAdmin == true;
    }

    function getUserMemberDocIds() {
      let email = request.auth.token.email;
      let aclPath = /databases/$(database)/documents/acl/$(email);
      return (email != null && exists(aclPath)) ? get(aclPath).data.memberDocIds : [];
    }

    function isFullMember() {
      let email = request.auth.token.email;
      let aclPath = /databases/$(database)/documents/acl/$(email);
      return email != null && exists(aclPath) && get(aclPath).data.get('notYetLinkedToMember', false) == false;
    }

    function isInstructor() {
      let email = request.auth.token.email;
      let aclPath = /databases/$(database)/documents/acl/$(email);
      return email != null && exists(aclPath) && get(aclPath).data.get('instructorIds', []).size() > 0;
    }

    match /members/{memberDocId} {
      function isOwner() {
        return (request.auth.token.email in resource.data.emails) || 
               (memberDocId in getUserMemberDocIds());
      }
      function isManagerOfMemberSchool() {
        let member = resource.data;
        let schoolDocId = member.primarySchoolDocId;
        let schoolPath = /databases/$(database)/documents/schools/$(schoolDocId);
        return schoolDocId != "" && exists(schoolPath) && (
          request.auth.token.email in get(schoolPath).data.get('ownerEmails', []) || 
          request.auth.token.email in get(schoolPath).data.get('managerEmails', [])
        );
      }
      function hasValidEditUpdate() {
        return request.resource.data.lastUpdated == request.time;
      }
      allow read: if isOwner() || isAdmin() || isManagerOfMemberSchool();
      allow delete: if isAdmin();
      allow write: if hasValidEditUpdate() && (isAdmin() || isManagerOfMemberSchool());
      allow update: if hasValidEditUpdate() && isOwner() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['lastUpdated', 'name', 'instructorWebsite', 'publicClassGoogleCalendarId', 'publicRegionOrCity', 'publicCountyOrState',
           'publicEmail', 'publicPhone', 'address', 'city', 'countyOrState', 'zipCode', 'country', 'phone', 
           'emails', 'gender', 'dateOfBirth', 'primaryInstructorId', 'primarySchoolId', 'primarySchoolDocId']);
    }

    match /instructors/{instructorMemberDocId} {
      allow read: if true;
      allow write: if false; // Locked down to Cloud Functions
      
      match /members/{studentMemberDocId} {
        allow read: if isAdmin() || instructorMemberDocId in getUserMemberDocIds();
        allow write: if isAdmin();
      }
      
      match /gradings/{gradingId} {
        allow read: if isAdmin() || instructorMemberDocId in getUserMemberDocIds();
        allow write: if isAdmin();
      }
    }

    match /schools/{schoolDocId} {
      function isSchoolManager() {
        let school = get(/databases/$(database)/documents/schools/$(schoolDocId)).data;
        return 
            request.auth.token.email in school.get('ownerEmails', []) || 
            request.auth.token.email in school.get('managerEmails', []);
      }
      function hasValidEditUpdate() {
        return request.resource.data.lastUpdated == request.time;
      }
      allow read: if true;
      allow write: if hasValidEditUpdate() && isAdmin();
      allow delete: if isAdmin();
      allow update: if hasValidEditUpdate() && isSchoolManager() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['lastUpdated', 'schoolName', 'schoolAddress', 'schoolZipCode', 'schoolWebsite', 'schoolClassGoogleCalendarId', 'managerInstructorIds']);
    
      match /members/{memberDocId} {
        allow read: if isAdmin() || isSchoolManager();
        allow write: if isAdmin();
      }

      match /gradings/{gradingId} {
        allow read: if isAdmin() || isSchoolManager();
        allow write: if isAdmin();
      }
    }

    match /acl/{email} {
      allow read: if request.auth.token.email == email || isAdmin();
      allow write: if isAdmin();
    }

    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /statistics/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Cached calendar events — publicly readable as events are public.
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cached members-area blog posts — readable by authenticated users.
    // Fine-grained membership checks are done in the frontend component;
    // the rule here ensures only logged-in users can access the data.
    match /members-post/{postId} {
      allow read: if request.auth != null && (isAdmin() || isFullMember());
      allow write: if isAdmin();
    }

    // Cached instructors blog posts — readable by active instructors or admins.
    match /instructors-post/{postId} {
      allow read: if request.auth != null && (isAdmin() || isInstructor());
      allow write: if isAdmin();
    }

    match /gradings/{gradingId} {
      function isGradingStudent() {
        return resource.data.studentMemberDocId in getUserMemberDocIds();
      }
      function isGradingInstructor() {
        let email = request.auth.token.email;
        let aclPath = /databases/$(database)/documents/acl/$(email);
        let instructorIds = (email != null && exists(aclPath)) ? get(aclPath).data.instructorIds : [];
        let asst = 'assistantInstructorIds' in resource.data ? resource.data.assistantInstructorIds : [];
        return resource.data.gradingInstructorId in instructorIds || instructorIds.hasAny(asst);
      }
      function isGradingSchoolManager() {
        let schoolId = resource.data.schoolId;
        let schoolPath = /databases/$(database)/documents/schools/$(schoolId);
        return schoolId != "" && exists(schoolPath) && (
          request.auth.token.email in get(schoolPath).data.ownerEmails ||
          request.auth.token.email in get(schoolPath).data.managerEmails
        );
      }
      function hasValidEditUpdate() {
        return request.resource.data.lastUpdated == request.time;
      }
      allow read: if isAdmin() || isGradingStudent() || isGradingInstructor() || isGradingSchoolManager();
      allow write: if hasValidEditUpdate() && isAdmin();
      allow delete: if isAdmin();
      allow update: if hasValidEditUpdate() && isGradingInstructor() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['lastUpdated', 'status', 'gradingEventDate', 'gradingEvent', 'notes']);
      allow update: if hasValidEditUpdate() && isGradingStudent() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['lastUpdated', 'gradingEvent', 'gradingInstructorId']);
    }
  }
}